# Port to run the server on (default: 4000)
PORT=4000

# Full path to your videos folder
# Windows example: VIDEO_DIR=C:\Users\family_2\Videos\SmartScope
# Default: ./videos (a folder next to server.js)
VIDEO_DIR=./videos

# Secret token — change this to something random!
# Anyone who knows this token can stream your videos.
VIDEO_TOKEN=smartscope-video-2026
